# 生产机最小 .env 示例（复制为部署目录下的 .env）

TV_IMAGE=ghcr.io/OWNER/tv:latest
HOST_PORT=8000
MEDIA_DIR=./media
DATA_DIR=./data

METATUBE_BASE_URL=https://openai-proxy.caowxj.eu.org
METATUBE_TOKEN=

# 另机 VPS 上的 Alist（TV 解析 AlistPath / 设置页）
ALIST_BASE_URL=https://alist.example.com
ALIST_TOKEN=

CORS_ORIGINS=*

# 日志 / 刮削翻译 / 图片代理（可选）
LOG_LEVEL=INFO
DEBUG=false
AUTO_TRANSLATE=true
# site | metatube | external
IMAGE_PROXY_MODE=site
# IMAGE_EXTERNAL_PROXY_URL=https://wsrv.nl/?url={url}
IMAGE_LOCAL_CACHE=false
# IMAGE_CACHE_MAX_MB=2048

# 可选 AutoFilm（profile autofilm；密钥在 config/autofilm/config.yaml）
AUTOFILM_IMAGE=akimio/autofilm:latest
AUTOFILM_LOG_DIR=./data/autofilm-logs
