# TV app reverse proxy example (TLS termination + Range-friendly streaming)
# Upstream: uvicorn / docker on 127.0.0.1:8000
#
# Usage:
#   1. Copy and edit server_name / ssl paths
#   2. nginx -t && systemctl reload nginx

upstream tv_upstream {
    server 127.0.0.1:8000;
    keepalive 32;
}

# Redirect HTTP -> HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name tv.example.com;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name tv.example.com;

    # ssl_certificate     /etc/letsencrypt/live/tv.example.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/tv.example.com/privkey.pem;
    # include /etc/letsencrypt/options-ssl-nginx.conf;
    # ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 32m;

    # Long timeouts for MetaTube scrape / large media
    proxy_connect_timeout 60s;
    proxy_send_timeout 3600s;
    proxy_read_timeout 3600s;
    send_timeout 3600s;

    # SPA + API all via app (static embedded in FastAPI)
    location / {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        proxy_pass http://tv_upstream;
    }

    # Video streaming — preserve Range, disable buffering
    location /api/stream/ {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Range $http_range;
        proxy_set_header If-Range $http_if_range;
        proxy_pass http://tv_upstream;
        proxy_buffering off;
        proxy_request_buffering off;
        proxy_max_temp_file_size 0;
        add_header Accept-Ranges bytes always;
    }

    # Image proxy cache at nginx (optional)
    location /api/images/proxy {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_pass http://tv_upstream;
        proxy_cache_valid 200 1h;
        add_header X-Cache-Status $upstream_cache_status always;
    }

    # Health (no auth) — useful for load balancers
    location = /api/health {
        proxy_pass http://tv_upstream;
        access_log off;
    }
}
