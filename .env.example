# ========== 镜像（compose 用）==========
# 发布后改成真实仓库，例如 ghcr.io/yourname/tv:latest 或 :0.1.0
TV_IMAGE=ghcr.io/OWNER/tv:latest
HOST_PORT=8000
# 宿主机路径（可改成绝对路径）
MEDIA_DIR=./media
DATA_DIR=./data

# 可选 AutoFilm（docker compose --profile autofilm）
# 详细配置在 config/autofilm/config.yaml，不在这里
AUTOFILM_IMAGE=akimio/autofilm:latest
AUTOFILM_LOG_DIR=./data/autofilm-logs

# ========== 应用运行时 ==========
# 容器内路径由 compose 注入，一般无需改 DATABASE_URL / MEDIA_ROOT
DATABASE_URL=sqlite:////data/app.db
MEDIA_ROOT=/media

# 远程 MetaTube（本机/本 compose 不部署）
METATUBE_BASE_URL=https://openai-proxy.caowxj.eu.org
METATUBE_TOKEN=

# 远程 Alist（另机 VPS，本 compose 不部署）
# 填公网或内网可达地址，需带协议；token 在 Alist 后台生成
ALIST_BASE_URL=https://alist.example.com
ALIST_TOKEN=

# 生产：若只通过本服务同源访问 SPA，可用 * 或具体域名
# 开发前后端分离时：http://127.0.0.1:5173,http://localhost:5173
CORS_ORIGINS=*

HOST=0.0.0.0
PORT=8000
AUTO_SCRAPE=true

# 单管理员登录：设置后除 /api/health 与 /api/auth/login 外需 JWT
# 留空则关闭鉴权（仅建议开发环境）
ADMIN_PASSWORD=
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_HOURS=72

# 默认刮削源（空=自动）；可在设置页覆盖
METATUBE_PROVIDER=
# 有序优先级 JSON 数组，如 ["JavBus","FANZA"]；非空时优先于 METATUBE_PROVIDER
# METATUBE_PROVIDER_PRIORITY=[]
METATUBE_FALLBACK=true

# 日志：默认 INFO；DEBUG=true 强制 DEBUG（排查 watcher/scrape 时打开）
# DEBUG=false 时关闭 uvicorn access 与 httpx 请求日志；DEBUG=true 打开
LOG_LEVEL=INFO
DEBUG=false

# 刮削后自动翻译（→ 简中）；可在设置页覆盖
AUTO_TRANSLATE=true
# 翻译引擎：google=免费 gtx；bing=免费 Edge 必应；可在设置页覆盖
TRANSLATE_PROVIDER=google

# 图片代理：site=本站 /api/images/proxy；metatube=MetaTube primary；external=外部模板
# 可在设置页覆盖
IMAGE_PROXY_MODE=site
# external 模式模板，须含 {url}（替换为 URL-encode 后的原始图地址）
# 可附加鉴权参数，例如：https://img.example.com/api?url={url}&key=your_secret
# IMAGE_EXTERNAL_PROXY_URL=https://wsrv.nl/?url={url}
# 本站代理磁盘缓存（仅 site 模式生效；文件在 data/image-cache）
IMAGE_LOCAL_CACHE=false
# IMAGE_CACHE_MAX_MB=2048
